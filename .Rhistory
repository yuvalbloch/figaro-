library(ggplot2)
p <- ggplot(iris, aes(Sepal.Length, Sepal.Width, color = Species)) +
geom_point() +
labs(title = "Iris scatter", x = "Sepal length (cm)", y = "Sepal width (cm)") +
theme(text = element_text(size = 14))
figaro(scatter = p)
